{
  "expo": {
    "name": "stone-wala-app",
    "slug": "stone-wala-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stonewalaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    }
  ],
  "expo-secure-store",
  "expo-video",
  [
    "expo-image-picker",
    {
      "photosPermission": "Allow Stone Wala to access your photos."
    }
  ],
  [
    "expo-media-library",
    {
      "photosPermission": "Allow Stone Wala to save generated images to your gallery.",
      "savePhotosPermission": "Allow Stone Wala to save generated images to your gallery.",
      "isAccessMediaLocationEnabled": true
    }
  ]
],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
